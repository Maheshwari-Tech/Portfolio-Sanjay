# Sample production values for AWS Lambda.
# Do not deploy this file and do not commit real credentials.
APP_ENV=production
AUTH_PROVIDER=supabase
RUNTIME_TARGET=lambda

# Supabase transaction pooler for a serverless Lambda service (port 6543).
# URL encode special characters in the database password.
DATABASE_URL=postgresql+psycopg://postgres.YOUR_PROJECT_REF:REPLACE_ME_URL_ENCODED_DATABASE_PASSWORD@YOUR_REGION.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

CORS_ORIGINS=https://portfolio-sanjay-tech.vercel.app
ADMIN_PHONE=+918847472124
JWT_SECRET=REPLACE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
OTP_HASH_SECRET=REPLACE_ME_WITH_A_DIFFERENT_32_CHARACTER_SECRET
OTP_EXPIRY_MINUTES=30
OTP_MAX_ATTEMPTS=5

# Local-auth fallback settings. They are ignored while AUTH_PROVIDER=supabase,
# because Supabase owns password, SMS OTP, email OTP, Twilio, and CAPTCHA.
ADMIN_INITIAL_PASSWORD=REPLACE_ME_LOCAL_FALLBACK_PASSWORD
EMAIL_OTP_PROVIDER=development
SMS_OTP_PROVIDER=development
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_ME_SMTP_USERNAME
SMTP_PASSWORD=REPLACE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Sanjay Gandhi Portfolio
TEXTLOCAL_API_KEY=REPLACE_ME_TEXTLOCAL_API_KEY
TEXTLOCAL_SENDER=SANJAY

# AWS supplies this automatically inside Lambda; do not configure it yourself.
# AWS_LAMBDA_FUNCTION_NAME=sanjay-portfolio-api
