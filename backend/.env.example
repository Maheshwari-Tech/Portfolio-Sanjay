# Local FastAPI + hosted Supabase. Copy to backend/.env and replace REPLACE_ME.
APP_ENV=development
AUTH_PROVIDER=supabase

# Supabase Session pooler for a normal local/container process (port 5432).
DATABASE_URL=postgresql+psycopg://postgres.yfkruidoqgfyiqxdgapi:REPLACE_ME_URL_ENCODED_DATABASE_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://yfkruidoqgfyiqxdgapi.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Exact browser origins only; no paths and no trailing slash.
CORS_ORIGINS=http://localhost:3001,http://portfolio.localtest.me:3001,https://portfolio-sanjay-tech.vercel.app

# Application authorization and local fallback signing secrets.
ADMIN_PHONE=+918847472124
JWT_SECRET=REPLACE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
OTP_HASH_SECRET=REPLACE_ME_WITH_A_DIFFERENT_32_CHARACTER_SECRET
OTP_EXPIRY_MINUTES=30
OTP_MAX_ATTEMPTS=5

# Only used when AUTH_PROVIDER=local. Twilio credentials are configured in
# Supabase Dashboard and must not be copied into this file.
ADMIN_INITIAL_PASSWORD=123456
EMAIL_OTP_PROVIDER=development
SMS_OTP_PROVIDER=development
